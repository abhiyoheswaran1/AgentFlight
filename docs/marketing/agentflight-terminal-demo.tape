Output docs/assets/agentflight-terminal-demo.gif

Require bash

Set Shell "zsh"
Set FontSize 22
Set Width 1200
Set Height 720
Set Theme "TokyoNight"
Set BorderRadius 10
Set WindowBar Colorful
Set TypingSpeed 12ms
Set PlaybackSpeed 1.25

Type "bash docs/marketing/agentflight-terminal-demo-playback.sh"
Enter
Sleep 16s
