Output docs/assets/agentflight-terminal-demo.gif

Require bash

Set Shell "zsh"
Set FontSize 20
Set Width 1120
Set Height 760
Set Theme "TokyoNight"
Set BorderRadius 10
Set WindowBar Colorful
Set TypingSpeed 18ms
Set PlaybackSpeed 1.0

Type "bash docs/marketing/agentflight-terminal-demo-playback.sh"
Enter
Sleep 16s
